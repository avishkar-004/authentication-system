# ========================================
# FRESHMARKET AUTHENTICATION SYSTEM
# Environment Configuration & Security Setup
# ========================================

# ===================
# SERVER CONFIGURATION
# ===================
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:5173

# ===================
# DATABASE CONFIGURATION
# ===================
DB_HOST=localhost
DB_PORT=3306
DB_USER=freshmarket_user
DB_PASSWORD=your_super_secure_database_password_here
DB_NAME=grocery_deliver

# Connection Pool Settings
DB_CONNECTION_LIMIT=10
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000

# ===================
# JWT CONFIGURATION
# ===================
# Generate these with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_256_bits_minimum_length_here_change_this_immediately
JWT_REFRESH_SECRET=your_jwt_refresh_secret_256_bits_minimum_length_here_change_this_too

# Token Expiration Times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===================
# PASSWORD HASHING
# ===================
# Higher numbers = more secure but slower (12-15 recommended for production)
BCRYPT_ROUNDS=12

# ===================
# EMAIL CONFIGURATION
# ===================
# Gmail SMTP (you can use other providers)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Email Settings
EMAIL_FROM_NAME=FreshMarket
EMAIL_FROM_ADDRESS=noreply@freshmarket.com

# ===================
# RATE LIMITING
# ===================
# Login attempts per 15 minutes
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=900000

# Registration attempts per 15 minutes
REGISTER_RATE_LIMIT=3
REGISTER_RATE_WINDOW=900000

# OTP requests per 5 minutes
OTP_RATE_LIMIT=3
OTP_RATE_WINDOW=300000

# ===================
# SESSION CONFIGURATION
# ===================
SESSION_TIMEOUT_MINUTES=1440
MAX_SESSIONS_PER_USER=5
SESSION_CLEANUP_INTERVAL=3600000

# ===================
# SECURITY SETTINGS
# ===================
# Account lockout after failed attempts
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=1800

# OTP Settings
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# Password Requirements
MIN_PASSWORD_LENGTH=8
REQUIRE_UPPERCASE=true
REQUIRE_LOWERCASE=true
REQUIRE_NUMBERS=true
REQUIRE_SPECIAL_CHARS=false

# ===================
# CORS CONFIGURATION
# ===================
CORS_ORIGIN=http://localhost:5173,https://yourproductiondomain.com
CORS_CREDENTIALS=true

# ===================
# LOGGING CONFIGURATION
# ===================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# ===================
# REDIS CONFIGURATION (Optional - for session storage)
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ===================
# FILE UPLOAD CONFIGURATION
# ===================
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp
UPLOAD_DESTINATION=./uploads

# ===================
# MONITORING & ANALYTICS
# ===================
ENABLE_AUDIT_LOGGING=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ERROR_TRACKING=true

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn_here

# ===================
# TWO-FACTOR AUTHENTICATION
# ===================
ENABLE_2FA=false
TOTP_ISSUER=FreshMarket
TOTP_WINDOW=1

# ===================
# CLEANUP SETTINGS
# ===================
CLEANUP_EXPIRED_SESSIONS_INTERVAL=86400000
CLEANUP_EXPIRED_OTPS_INTERVAL=3600000
CLEANUP_OLD_AUDIT_LOGS_DAYS=90

# ===================
# DEVELOPMENT SETTINGS
# ===================
# Set to true only in development
DEBUG_MODE=false
ENABLE_SQL_LOGGING=false
SKIP_EMAIL_VERIFICATION=false

# ===================
# API DOCUMENTATION
# ===================
ENABLE_API_DOCS=true
API_DOCS_PATH=/api-docs

# ===================
# HEALTH CHECK
# ===================
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_DB=true
HEALTH_CHECK_REDIS=false

# ===================
# BACKUP CONFIGURATION
# ===================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=./backups

# ========================================
# DOCKER ENVIRONMENT VARIABLES
# ========================================

# Database Service
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=grocery_deliver
MYSQL_USER=freshmarket_user
MYSQL_PASSWORD=your_super_secure_database_password_here

# Redis Service
REDIS_PASSWORD=your_redis_password

# ========================================
# PRODUCTION SECURITY CHECKLIST
# ========================================

# 1. Change all default passwords
# 2. Generate strong JWT secrets (256+ bits)
# 3. Enable HTTPS in production
# 4. Set up proper firewall rules
# 5. Enable database SSL/TLS
# 6. Set up monitoring and alerting
# 7. Configure regular backups
# 8. Set up log rotation
# 9. Enable fail2ban or similar
# 10. Regular security updates

