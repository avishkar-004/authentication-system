# ========================================
# SYSTEMD SERVICE CONFIGURATION
# ========================================

# File: /etc/systemd/system/freshmarket-api.service
# [Unit]
# Description=FreshMarket API Server
# After=network.target
# 
# [Service]
# Type=simple
# User=www-data
# WorkingDirectory=/var/www/freshmarket-api
# ExecStart=/usr/bin/node index.js
# Restart=always
# RestartSec=10
# Environment=NODE_ENV=production
# EnvironmentFile=/var/www/freshmarket-api/.env
# 
# # Security settings
# NoNewPrivileges=true
# PrivateTmp=true
# ProtectSystem=strict
# ProtectHome=true
# ReadWritePaths=/var/www/freshmarket-api/uploads /var/www/freshmarket-api/logs
# 
# # Resource limits
# LimitNOFILE=65536
# LimitNPROC=4096
# 
# [Install]
# WantedBy=multi-user.target

