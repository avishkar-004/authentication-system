# ========================================
# MONITORING & ALERTING
# ========================================

# Prometheus metrics endpoint
METRICS_ENABLED=true
METRICS_PATH=/metrics

# Health check endpoints
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000

# Log aggregation (ELK Stack)
ELASTICSEARCH_URL=http://localhost:9200
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5044

# ========================================
# BACKUP SCRIPTS
# ========================================

# Database backup script (backup.sh)
# #!/bin/bash
# BACKUP_DIR="/var/backups/freshmarket"
# DATE=$(date +%Y%m%d_%H%M%S)
# 
# # Create backup directory
# mkdir -p $BACKUP_DIR
# 
# # Database backup
# mysqldump -h $DB_HOST -u $DB_USER -p$DB_PASSWORD $DB_NAME | gzip > $BACKUP_DIR/db_backup_$DATE.sql.gz
# 
# # Remove backups older than 30 days
# find $BACKUP_DIR -name "db_backup_*.sql.gz" -mtime +30 -delete
# 
# # Upload to cloud storage (optional)
# # aws s3 cp $BACKUP_DIR/db_backup_$DATE.sql.gz s3://your-backup-bucket/

# ========================================
# SECURITY HARDENING SCRIPT
# ========================================

# File: security-setup.sh
# #!/bin/bash
# 
# # Install fail2ban
# sudo apt-get install fail2ban -y
# 
# # Configure fail2ban for SSH
# sudo cp /etc/fail2ban/jail.conf /etc/fail2ban/jail.local
# 
# # Configure firewall
# sudo ufw default deny incoming
# sudo ufw default allow outgoing
# sudo ufw allow ssh
# sudo ufw allow 80
# sudo ufw allow 443
# sudo ufw enable
# 
# # Set up automatic security updates
# sudo apt-get install unattended-upgrades -y
# sudo dpkg-reconfigure -plow unattended-upgrades
# 
# # Secure MySQL installation
# sudo mysql_secure_installation
# 
# # Set up log rotation
# sudo logrotate -f /etc/logrotate.conf

# ========================================
# DEVELOPMENT SETUP INSTRUCTIONS
# ========================================

# 1. Clone the repository
# 2. Copy .env.example to .env
# 3. Fill in all environment variables
# 4. Install dependencies: npm install
# 5. Set up database: mysql -u root -p < schema.sql
# 6. Start development server: npm run dev

# ========================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ========================================

# Pre-deployment:
# □ Update all dependencies
# □ Run security audit: npm audit
# □ Update environment variables
# □ Test database migrations
# □ Verify SSL certificates
# □ Set up monitoring
# □ Configure backups
# □ Set up log rotation
# □ Configure firewall
# □ Set up fail2ban

# Post-deployment:
# □ Verify all endpoints
# □ Check logs for errors
# □ Test authentication flow
# □ Verify email delivery
# □ Test rate limiting
# □ Check database performance
# □ Verify monitoring alerts
# □ Test backup restoration