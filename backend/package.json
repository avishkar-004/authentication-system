{
  "name": "freshmarket-auth-api",
  "version": "2.0.0",
  "description": "Optimized authentication system for FreshMarket grocery delivery platform",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "security:audit": "npm audit && snyk test",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:reset": "node scripts/reset-db.js",
    "logs:clear": "rm -rf logs/*.log",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop freshmarket-api",
    "pm2:restart": "pm2 restart freshmarket-api",
    "pm2:logs": "pm2 logs freshmarket-api",
    "docker:build": "docker build -t freshmarket-api .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "backup:db": "node scripts/backup-database.js",
    "cleanup:sessions": "node scripts/cleanup-sessions.js",
    "generate:keys": "node scripts/generate-jwt-keys.js",
    "health:check": "curl -f http://localhost:5000/health || exit 1"
  },
  "keywords": [
    "authentication",
    "jwt",
    "nodejs",
    "express",
    "mysql",
    "grocery",
    "api",
    "security"
  ],
  "author": "FreshMarket Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.7",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.3.1",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "cookie-parser": "^1.4.6",
    "express-session": "^1.17.3",
    "connect-redis": "^7.1.0",
    "redis": "^4.6.10",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "moment": "^2.29.4",
    "crypto": "^1.0.1",
    "validator": "^13.11.0",
    "express-mongo-sanitize": "^2.2.0",
    "xss": "^1.0.14",
    "hpp": "^0.2.3",
    "express-slow-down": "^2.0.1",
    "node-cron": "^3.0.3",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "ua-parser-js": "^1.0.37",
    "geoip-lite": "^1.4.8",
    "nodemailer-html-to-text": "^3.2.0",
    "express-prometheus-middleware": "^1.2.0",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-security": "^1.7.1",
    "prettier": "^3.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "cross-env": "^7.0.3",
    "snyk": "^1.1266.0",
    "@types/node": "^20.10.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/freshmarket/auth-api.git"
  },
  "bugs": {
    "url": "https://github.com/freshmarket/auth-api/issues"
  },
  "homepage": "https://github.com/freshmarket/auth-api#readme",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run test && npm run security:audit"
    }
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "**/*.{js,jsx}",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/logs/**",
      "!**/uploads/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ],
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"]
  },
  "eslintConfig": {
    "extends": [
      "airbnb-base",
      "plugin:security/recommended"
    ],
    "env": {
      "node": true,
      "jest": true
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "error",
      "prefer-const": "error",
      "no-var": "error",
      "object-shorthand": "error",
      "prefer-arrow-callback": "error",
      "security/detect-object-injection": "warn",
      "security/detect-non-literal-regexp": "warn"
    }
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "printWidth": 100
  },
  "nodemonConfig": {
    "ignore": [
      "logs/*",
      "uploads/*",
      "coverage/*",
      "*.test.js"
    ],
    "env": {
      "NODE_ENV": "development"
    }
  }
}